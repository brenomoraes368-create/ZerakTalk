{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@zeraktalk/ai-adapters": [
        "packages/ai-adapters/src/index.ts"
      ],
      "@zeraktalk/debate-engine": [
        "packages/debate-engine/src/index.ts"
      ],
      "@zeraktalk/ui": [
        "packages/ui/src/index.ts"
      ]
    },
    "ignoreDeprecations": "6.0"
  }
}
