{
  "name": "zeraktalk",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma de debates entre IAs com Next.js, Electron e adaptadores de modelos.",
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev --workspace @zeraktalk/web",
    "dev:web": "npm run dev --workspace @zeraktalk/web",
    "dev:desktop": "npm run dev --workspace @zeraktalk/desktop",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
